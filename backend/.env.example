# Copy to .env and fill in before running.

# Set a long random string to lock down all routes (API + image files).
# Without this, anyone on the same network can browse your photos.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=

# Default: 127.0.0.1 (localhost only, safe).
# Set to 0.0.0.0 to allow access from your phone (requires API_TOKEN above).
HOST=127.0.0.1

# SQLite database location (leave as-is for default).
# DATABASE_URL=sqlite+aiosqlite:///./photosync.db

# Trash auto-empty window in days (default 30).
# TRASH_RETENTION_DAYS=30

# ── Local AI (CLIP) — semantic search + auto-tagging ─────────────────────────
# Fully on-device, no API key, no cost, nothing uploaded. To enable:
#   pip install -r requirements-ai.txt   (then POST /api/photos/analyze)
# These have sensible defaults; override only if you know what you're doing.
# CLIP_MODEL=clip-ViT-B-32
# AI_TAG_THRESHOLD=0.22
# AI_MAX_TAGS=8

# Copy to .env and fill in before running.

# Set a long random string to lock down all routes (API + image files).
# Without this, anyone on the same network can browse your photos.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=

# Default: 127.0.0.1 (localhost only, safe).
# Set to 0.0.0.0 to allow access from your phone (requires API_TOKEN above).
HOST=127.0.0.1

# SQLite database location (leave as-is for default).
# DATABASE_URL=sqlite+aiosqlite:///./photosync.db

# Trash auto-empty window in days (default 30).
# TRASH_RETENTION_DAYS=30

# SAFETY (default False): emptying Trash / permanent-delete will NOT delete
# folder-imported original files that live outside uploads/ — only PhotoSync's
# own thumbnails, previews, and uploaded copies. Leave False to protect an
# un-backed-up source library. Set True only if your imported folder is a
# disposable copy you intend to cull for real.
# DELETE_IN_PLACE_ORIGINALS=false

# Allowed browser origins (comma-separated). Add your machine's LAN address here
# if you open the UI from another device on a non-default host/port.
# CORS_ORIGINS=http://localhost:5173,http://192.168.1.20:5173

# Max accepted upload size per file, in MB (default 50).
# MAX_UPLOAD_SIZE_MB=50

# ── Local AI (CLIP) — semantic search + auto-tagging ─────────────────────────
# Fully on-device, no API key, no cost, nothing uploaded. To enable:
#   pip install -r requirements-ai.txt   (then POST /api/photos/analyze)
# These have sensible defaults; override only if you know what you're doing.
# CLIP_MODEL=clip-ViT-B-32      # try clip-ViT-L-14 for sharper (slower) search
# AI_TAG_THRESHOLD=0.22
# AI_MAX_TAGS=8

# ── Local face recognition (group photos by person) ──────────────────────────
# Detect + cluster faces so you can name who you know and bulk-cull who you don't.
# On-device (InsightFace/ArcFace); buffalo_l model (~300MB) downloads once.
# FACE_MATCH_THRESHOLD=0.45     # higher = stricter (fewer faces merged per person)
# FACE_MIN_DET_SCORE=0.60       # ignore low-confidence detections
# FACE_MIN_SIZE=40              # ignore faces smaller than this (px)
